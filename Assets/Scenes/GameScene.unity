  m_Script: {fileID: 11500000, guid: ed4e049cf91f9624eb51e559a66d459d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  dialoguePanel: {fileID: 475293607}
  nameText: {fileID: 1110507829}
  dialogueText: {fileID: 1623120703}
  interactPrompt: {fileID: 1415884337}
  contButton: {fileID: 1023822746}
  isAutoPlay: 0
  autoPlayDelay: 2
  player: {fileID: 1995513867}
  dialogueLines:
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E09\u0E31\u0E19\u0E21\u0E32\u0E23\u0E2D\u0E1E\u0E35\u0E48\u0E48\u0E17\u0E35\u0E48\u0E17\u0E48\u0E32\u0E19\u0E49\u0E33\u0E17\u0E38\u0E01\u0E27\u0E31\u0E19\u0E40\u0E25\u0E22\u0E2B\u0E19\u0E32
      \u0E1E\u0E35\u0E48\u0E43\u0E2B\u0E49\u0E09\u0E31\u0E19\u0E23\u0E2D\u0E19\u0E32\u0E19\u0E46\u0E21\u0E31\u0E19\u0E01\u0E47\u0E2D\u0E32\u0E08\u0E08\u0E30\u0E1A\u0E31\u0E48\u0E19\u0E17\u0E2D\u0E19\u0E14\u0E27\u0E07\u0E43\u0E08\u0E19\u0E49\u0E2D\u0E07\u0E44\u0E14\u0E49\u0E19\u0E30\u0E1E\u0E35\u0E48\u0E08\u0E4B\u0E32
      \u0E41\u0E25\u0E09\u0E31\u0E19\u0E15\u0E49\u0E2D\u0E07\u0E1E\u0E22\u0E32\u0E22\u0E32\u0E21\u0E2D\u0E35\u0E01\u0E19\u0E32\u0E19\u0E40\u0E17\u0E48\u0E32\u0E44\u0E2B\u0E23\u0E48
      \u0E1E\u0E35\u0E48\u0E21\u0E32\u0E01\u0E16\u0E36\u0E07\u0E08\u0E31\u0E01\u0E01\u0E25\u0E31\u0E1A\u0E21\u0E32\u0E40\u0E2B\u0E25\u0E48\u0E32
      \u0E2D\u0E30\u0E2E\u0E37\u0E48\u0E2D.."
  - name: "\u0E1C\u0E39\u0E49\u0E40\u0E25\u0E48\u0E19"
    sentence: ...
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "!!! \u0E40\u0E08\u0E49\u0E32\u0E40\u0E1B\u0E47\u0E19\u0E1C\u0E39\u0E49\u0E43\u0E14\u0E01\u0E31\u0E19
      \u0E43\u0E22\u0E21\u0E32\u0E40\u0E25\u0E48\u0E19\u0E19\u0E49\u0E33\u0E2B\u0E19\u0E49\u0E32\u0E1A\u0E49\u0E32\u0E19\u0E02\u0E49\u0E32"
  - name: "\u0E1C\u0E39\u0E49\u0E40\u0E25\u0E48\u0E19"
    sentence: "(\u0E2A\u0E20\u0E32\u0E1E\u0E1C\u0E21\u0E40\u0E2B\u0E21\u0E37\u0E2D\u0E19\u0E04\u0E19\u0E40\u0E25\u0E48\u0E19\u0E19\u0E49\u0E33\u0E2B\u0E23\u0E2D\u0E04\u0E23\u0E31\u0E1A)\n\u0E1A\u0E38\u0E4B\u0E07\u0E46"
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E1A\u0E38\u0E4B\u0E07\u0E46 \u0E2D\u0E30\u0E44\u0E23\u0E02\u0E2D\u0E07\u0E40\u0E08\u0E49\u0E32
      \u0E2B\u0E25\u0E2D\u0E01\u0E14\u0E48\u0E32\u0E02\u0E49\u0E32\u0E40\u0E23\u0E4A\u0E2D\u0E30\n\r\n"
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E0A\u0E48\u0E32\u0E07\u0E40\u0E16\u0E2D\u0E30\u0E40\u0E08\u0E49\u0E32\u0E44\u0E21\u0E48\u0E08\u0E33\u0E40\u0E1B\u0E47\u0E19\u0E15\u0E49\u0E2D\u0E07\u0E15\u0E2D\u0E1A
      \u0E40\u0E1E\u0E23\u0E32\u0E30\u0E19\u0E2D\u0E01\u0E08\u0E32\u0E01\u0E1E\u0E35\u0E48\u0E21\u0E32\u0E01
      \u0E02\u0E49\u0E32\u0E01\u0E47\u0E21\u0E34\u0E44\u0E14\u0E49\u0E41\u0E25\u0E0A\u0E32\u0E22\u0E2D\u0E37\u0E48\u0E19\u0E14\u0E2D\u0E01\r\n"
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E40\u0E09\u0E01\u0E40\u0E0A\u0E48\u0E19\u0E19\u0E31\u0E49\u0E19\u0E41\u0E25\u0E49\u0E27
      \u0E40\u0E08\u0E49\u0E32\u0E08\u0E30\u0E0A\u0E48\u0E27\u0E22\u0E02\u0E49\u0E32\u0E15\u0E32\u0E21\u0E2B\u0E32\u0E1E\u0E35\u0E48\u0E21\u0E32\u0E01\u0E43\u0E0A\u0E48\u0E2B\u0E23\u0E37\u0E2D\u0E44\u0E21\u0E48
      \n"
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E40\u0E2B\u0E15\u0E38\u0E43\u0E14\u0E16\u0E36\u0E07\u0E44\u0E21\u0E48\u0E40\u0E2D\u0E48\u0E22\u0E15\u0E2D\u0E1A
      \u0E02\u0E49\u0E32\u0E15\u0E32\u0E21\u0E27\u0E48\u0E32\u0E43\u0E0A\u0E48 \u0E2B\u0E23\u0E37\u0E2D
      \u0E44\u0E21\u0E48"
  - name: "\u0E1C\u0E39\u0E49\u0E40\u0E25\u0E48\u0E19"
    sentence: "\u0E1A\u0E38\u0E4B\u0E07\u0E46 (\u0E41\u0E25\u0E49\u0E27\u0E09\u0E31\u0E19\u0E40\u0E25\u0E37\u0E2D\u0E01\u0E2D\u0E30\u0E44\u0E23\u0E44\u0E14\u0E49\u0E44\u0E2B\u0E21
      \u0E40\u0E25\u0E37\u0E2D\u0E01\u0E17\u0E35\u0E48\u0E08\u0E30\u0E44\u0E21\u0E48\u0E15\u0E32\u0E21\u0E2B\u0E32\u0E44\u0E14\u0E49\u0E2B\u0E23\u0E37\u0E2D\u0E40\u0E1B\u0E25\u0E48\u0E32)"
  - name: "\u0E41\u0E21\u0E48\u0E19\u0E32\u0E04"
    sentence: "\u0E15\u0E32\u0E21\u0E02\u0E49\u0E32\u0E21\u0E32\u0E17\u0E35\u0E48\u0E17\u0E48\u0E32\u0E40\u0E23\u0E37\u0E2D"
  wordSpeed: 0.03
  nextSceneName: ChoiceGame1
